{
  "name": "skytip-simple",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run lex && react-router build",
    "generate-jwk": "node scripts/generate-jwk.mjs",
    "lex": "npx lex build --lexicons ./lexicons/schemas --out ./app/lexicons --clear",
    "cf-typegen": "wrangler types",
    "deploy": "node scripts/ensure-secret.mjs && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@atiproto/agent": "^0.5.1",
    "@atiproto/edge-oauth-client": "^0.1.0",
    "@atiproto/edge-resolver-cache": "^0.0.1",
    "@atiproto/edge-resolvers": "^0.0.1",
    "@atiproto/kv-oauth-state-store": "^0.0.1",
    "@atiproto/lexicons": "^0.5.3",
    "@atproto/api": "^0.19.8",
    "@atproto/jwk": "^0.6.0",
    "@atproto/jwk-jose": "^0.1.11",
    "isbot": "^5.1.31",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.10.0"
  },
  "devDependencies": {
    "@atproto/lex": "^0.0.25",
    "@cloudflare/vite-plugin": "^1.13.5",
    "@react-router/dev": "^7.10.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.83.0"
  }
}
